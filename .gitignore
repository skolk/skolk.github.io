# Jekyll build output — rebuilt on every push, no value in committing
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# MCP / tooling caches
.playwright-mcp/

# Bundler / Ruby
vendor/bundle/
.bundle/

# macOS junk
.DS_Store

# Editor / OS
.vscode/
.idea/
*.swp
*.swo

# Local-only scratch (anything that should never leave the laptop)
.scratch/

# Raw Instagram data export (full DM/message archive + binary media). Source material
# for the imported _drafts; the converted posts + their images are committed, the raw
# export is private and stays local only.
_drafts/instagram-s.a.kolk-2026-06-22-l6dqQ6Ax/

# Squarespace .docx archive: heavy + redundant. The converted .md (text) is committed;
# the source .docx and its 71 extracted images are kept locally but not versioned, the
# images are renumbered/re-encoded copies of the photos already in images/blog_posts/ and
# _backend/archive/squarespace-2024/images/. See _backend/archive/README.md.
_backend/archive/squarespace-2024-docx/*.docx
_backend/archive/squarespace-2024-docx/media/
